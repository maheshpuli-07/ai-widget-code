# ── Chat widget API (`src/main.jsx` / `npm run dev` + `npm run dev:app`) ─────
# Optional: override the dev default (`DEV_WIDGET_API_BASE` in `publicApiBase.js`,
# currently http://localhost:3090). Never commit `.env`.
#
# VITE_WIDGET_API_BASE=http://localhost:3090
#
# Point dev preview at production (rare):
# VITE_WIDGET_API_BASE=https://ai-assistance-service.onrender.com

# ── Optional embed auth (unchanged) ─────────────────────────────────────────
# VITE_ACCESS_TOKEN=
# VITE_GENERAL_API_KEY=
# VITE_TENANT_ID=
# VITE_EMBED_KEY=
# JSON body fields (optional; see src/api.js sendChatMessage)
# VITE_CLIENT_ID=
# VITE_CLIENT_IP=   # public IP — usually leave unset in dev; production pages often inject from server

# Callback form (name / email / phone) — `src/main.jsx` defaults to /api/v1/contact-lead when unset.
# Set to empty to hide the card in local dev: VITE_CONTACT_LEAD_PATH=
# VITE_CONTACT_LEAD_PATH=/api/v1/contact-lead

# ── Legacy dev app proxy (vite.config.js `dev:app`) ──────────────────────────
# API_PROXY_TARGET=http://localhost:9000
